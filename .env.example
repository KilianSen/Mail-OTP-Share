# ─── Application ───────────────────────────────────────────────
# REQUIRED: Change to a long random string in production
APP_SECRET_KEY=change-me-in-production-use-a-long-random-string

# Public base URL of your deployment (no trailing slash)
APP_BASE_URL=http://localhost:8000

# Set to "true" for verbose logging
DEBUG=false

# ─── OpenID Connect ─────────────────────────────────────────────
# Register your app with an OIDC provider (e.g. Keycloak, Auth0, Google, etc.)
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
# e.g. https://accounts.google.com/.well-known/openid-configuration
OIDC_DISCOVERY_URL=https://your-provider/.well-known/openid-configuration
OIDC_SCOPE=openid email profile

# ─── App IMAP (for receiving command emails) ────────────────────
APP_IMAP_HOST=imap.example.com
APP_IMAP_PORT=993
APP_IMAP_USER=otpshare@example.com
APP_IMAP_PASSWORD=your-imap-password
APP_IMAP_TLS=true

# ─── App SMTP (for sending notification emails) ─────────────────
APP_SMTP_HOST=smtp.example.com
APP_SMTP_PORT=587
APP_SMTP_USER=otpshare@example.com
APP_SMTP_PASSWORD=your-smtp-password
APP_SMTP_TLS=true
APP_SMTP_FROM=OTP Share <otpshare@example.com>

# ─── OTP Sharing Defaults ───────────────────────────────────────
# Duration (seconds) an approved OTP share stays active (default 1 hour)
DEFAULT_OTP_SHARE_DURATION=3600

# Approval mode: "auto" = auto-approve after timeout, "strict" = must explicitly approve
DEFAULT_APPROVAL_MODE=auto

# Seconds before auto-approve triggers in "auto" mode (default 10 minutes)
DEFAULT_AUTO_APPROVE_TIMEOUT=600

# ─── Admin Bootstrap ────────────────────────────────────────────
# The first user to log in with this email will be made an admin
ADMIN_EMAIL=admin@example.com
